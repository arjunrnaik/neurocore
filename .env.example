# Telegram Bot configuration (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini AI configuration (from aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq Whisper Voice Transcription API key (from console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Google Sheets Dashboard Mirror configuration
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_JSON=./service_account.json

# Local persistent SQLite database path
DB_PATH=./neurocore.db
